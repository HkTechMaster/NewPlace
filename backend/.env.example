# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/placement_system?retryWrites=true&w=majority

# Google OAuth Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Session Secret
SESSION_SECRET=your_session_secret_key_change_this

# App URLs
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Port
PORT=5000

# Super Admin Email (pre-seeded in DB)
SUPER_ADMIN_EMAIL=superadmin@placement.edu
